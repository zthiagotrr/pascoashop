{
  "routes": [
    {
      "src": "^/$",
      "dest": "/promodepascoaa.shop/index.html"
    },
    {
      "src": "^/index\\.html$",
      "dest": "/promodepascoaa.shop/index.html"
    },
    {
      "src": "^/css/(.*)$",
      "dest": "/promodepascoaa.shop/css/$1"
    },
    {
      "src": "^/js/(.*)$",
      "dest": "/promodepascoaa.shop/js/$1"
    },
    {
      "src": "^/images/(.*)$",
      "dest": "/promodepascoaa.shop/images/$1"
    },
    {
      "src": "^/wa\\.html$",
      "dest": "/promodepascoaa.shop/wa.html"
    },
    {
      "src": "^/url, window.location\\.html$",
      "dest": "/promodepascoaa.shop/url, window.location.html"
    }
  ]
}